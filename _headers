# Cloudflare Pages _headers file — applied at the edge.
#
# Goal: HTML cached at the edge so brief deploy cutovers + origin hiccups
# don't surface as 522s. Pages dynamic functions (/api/*) stay no-store so
# the chatbot health probe + streaming chat keep working in real-time.
#
# Order matters: more specific paths first. Cloudflare matches top-down
# and a request only takes the FIRST matching rule.

/api/*
  Cache-Control: no-store

/*.html
  Cache-Control: public, max-age=60, stale-while-revalidate=300

/
  Cache-Control: public, max-age=60, stale-while-revalidate=300
